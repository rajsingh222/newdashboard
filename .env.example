# ── Server ──
PORT=5000
NODE_ENV=production

# ── MongoDB ──
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/dashboard?retryWrites=true&w=majority

# ── JWT ──
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ── CORS — Frontend URL(s) ──
# Comma-separated if multiple (e.g. https://yourdomain.com,https://www.yourdomain.com)
CLIENT_URL=https://yourdomain.com

# ── Realtime Worker ──
# Every 5 seconds by default for near-instant FTP-trigger pickup
REALTIME_WORKER_SCHEDULE=*/5 * * * * *
# Max number of newly-arrived files processed per project in each realtime cycle
REALTIME_MAX_FILES_PER_PROJECT=5
CRON_TZ=UTC

# Socket fallback polling interval in milliseconds when Mongo change streams are unavailable
EVENT_BROADCAST_POLL_INTERVAL_MS=1000

# SHM live parser preference: "python" (default) or "js"
SHM_LIVE_PARSER=python

# ── Gemini Chatbot ──
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_OUTPUT_TOKENS=450

# ── Cloudinary Storage ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER_ROOT=Dashboard

# -- Event Trigger API + Backup Cron --
# Optional shared secret required in POST /api/event-trigger header x-event-trigger-key
EVENT_TRIGGER_API_KEY=

# Backup missed-file scan (every 60 seconds by default)
EVENT_TRIGGER_BACKUP_ENABLED=false
EVENT_TRIGGER_BACKUP_SCHEDULE=0 * * * * *
EVENT_TRIGGER_BACKUP_MAX_FILES_PER_PROJECT=1

# Number of fingerprint keys retained in Project.processedFiles
MAX_PROCESSED_FILE_KEYS=5000
